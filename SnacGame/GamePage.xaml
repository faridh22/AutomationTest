<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="SnacGame.GamePage">

    <Grid>
        <!-- The Game Canvas -->
        <skia:SKCanvasView x:Name="gameCanvas"
                           PaintSurface="OnPaintSurface" />

        <!-- Simple Debug Controls -->
        <VerticalStackLayout VerticalOptions="End" HorizontalOptions="Center" Spacing="10" Margin="20">
            <Button Text="Up" Clicked="OnUpClicked" WidthRequest="80"/>
            <HorizontalStackLayout Spacing="20">
                <Button Text="Left" Clicked="OnLeftClicked" WidthRequest="80"/>
                <Button Text="Right" Clicked="OnRightClicked" WidthRequest="80"/>
            </HorizontalStackLayout>
            <Button Text="Down" Clicked="OnDownClicked" WidthRequest="80"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
