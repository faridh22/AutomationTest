<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             xmlns:viewModels="clr-namespace:Automation_APP.ViewModels"
             x:Class="Automation_APP.Views.GamePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#07111f">
    <ContentPage.BindingContext>
        <viewModels:GameViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <skia:SKCanvasView x:Name="GameCanvas"
                           EnableTouchEvents="True"
                           PaintSurface="OnPaintSurface"
                           Touch="OnCanvasTouch" />

        <Grid Padding="24" InputTransparent="True">
            <VerticalStackLayout Spacing="4">
                <Label Text="SNAC GAME" TextColor="#8df7a7" FontAttributes="Bold" FontSize="18" />
                <Label Text="{Binding Score, StringFormat='Score: {0}'}" TextColor="White" FontSize="16" />
                <Label Text="{Binding HighScore, StringFormat='High Score: {0}'}" TextColor="#b8c7d9" FontSize="14" />
            </VerticalStackLayout>
        </Grid>

        <Border IsVisible="{Binding IsGameOver}"
                BackgroundColor="#dd07111f"
                Stroke="#8df7a7"
                StrokeThickness="2"
                Padding="28"
                HorizontalOptions="Center"
                VerticalOptions="Center">
            <VerticalStackLayout Spacing="16">
                <Label Text="GAME OVER" TextColor="#ff6b6b" FontSize="30" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                <Label Text="{Binding Score, StringFormat='Final score: {0}'}" TextColor="White" HorizontalTextAlignment="Center" />
                <Button Text="Play Again" Command="{Binding RestartCommand}" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
